# Possible values: local, staging, production, ci, testing, other
ENVIRONMENT=local
# Generate the key. `php tempest key:generate`
SIGNING_KEY=

# The base URI that's used for all generated URIs
BASE_URI=http://app.localhost:8080

# Setting to `false` force-disable internal caches.
INTERNAL_CACHES=true

# Enable or disable discovery cache. Can be `true`, `partial` or `false`.
DISCOVERY_CACHE=false

# Overwrite default log paths (null = default)
DEBUG_LOG_PATH=/var/www/app/log/debug
SERVER_LOG_PATH=/var/www/app/log/server
